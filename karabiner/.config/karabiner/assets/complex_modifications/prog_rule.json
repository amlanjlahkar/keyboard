{
   "rules": [
      {
         "description": "Progrule: Firefox",
         "manipulators": [
            {
               "conditions": [
                  {
                     "bundle_identifiers": [
                        "org\\.mozilla\\.firefox"
                     ],
                     "type": "frontmost_application_if"
                  }
               ],
               "from": {
                  "key_code": "z",
                  "modifiers": {
                     "mandatory": [
                        "left_shift",
                        "left_control",
                        "left_option",
                        "left_command"
                     ]
                  }
               },
               "to": {
                  "key_code": "z",
                  "modifiers": [
                     "left_control"
                  ]
               },
               "type": "basic"
            }
         ]
      },
      {
         "description": "Progrule: Helium",
         "manipulators": [
            {
               "conditions": [
                  {
                     "bundle_identifiers": [
                        "^net\\.imput\\.helium$"
                     ],
                     "type": "frontmost_application_if"
                  }
               ],
               "from": {
                  "key_code": "a",
                  "modifiers": {
                     "mandatory": [
                        "left_control"
                     ]
                  }
               },
               "to": {
                  "key_code": "a",
                  "modifiers": [
                     "left_command",
                     "left_shift"
                  ]
               },
               "type": "basic"
            }
         ]
      }
   ],
   "title": "Program specific rules"
}
